# ═══════════════════════════════════════════════════════════
# WhatsBot-Fix — Variables de Entorno
# ⚠️ NUNCA subir este archivo a GitHub
# Agregar estas variables en: Netlify → Site Settings → Environment Variables
# ═══════════════════════════════════════════════════════════

# ─── Meta WhatsApp API (OBLIGATORIO) ──────────────────────
# Obtener en: developers.facebook.com → Tu App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID_AQUI
WHATSAPP_ACCESS_TOKEN=TU_ACCESS_TOKEN_AQUI
WEBHOOK_VERIFY_TOKEN=edfix2025secret

# ─── Admin Panel ──────────────────────────────────────────
# Token para acceder al panel admin y API
ADMIN_TOKEN=edfix-admin-2025

# ─── Datos del Negocio ────────────────────────────────────
# Personalizar para CADA cliente
BUSINESS_NAME=Mi Negocio
BUSINESS_PHONE=+51 999 999 999
BUSINESS_HOURS=Lunes a Sabado 9am - 6pm
BUSINESS_ADDRESS=Jr. Las Flores 123, Lima
BUSINESS_SERVICES=Servicio 1,Servicio 2,Servicio 3
BUSINESS_GREETING=¡Hola! 👋 Soy el asistente de {business}. ¿En qué te puedo ayudar hoy?

# ─── IA Gemini (OPCIONAL — Gratis) ───────────────────────
# Obtener en: aistudio.google.com → Get API Key
# Gratis: 15 req/min, 1.5M tokens/mes con gemini-1.5-flash
GEMINI_API_KEY=

# ─── Supabase (OPCIONAL — Para guardar leads en nube) ─────
# Crear en: supabase.com → New Project
# Gratis: 500MB, 50,000 requests/mes
SUPABASE_URL=
SUPABASE_ANON_KEY=
